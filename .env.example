# Foundry Studio env (FB-005). Copy to .env.local for dev. Real secrets live on the deployment
# env (Vercel) / venture box, never in the repo (D8). Auth wiring completes at deploy (FB-009).

# Auth.js — generate with `openssl rand -base64 32`
AUTH_SECRET=
# Set true off-Vercel (e.g. a VPS) so Auth.js trusts the host
AUTH_TRUST_HOST=true

# Google OAuth client (the Holy Corner vertical-login). Create in Google Cloud console;
# authorized redirect URI: https://<host>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Bruntsfield admin emails (see all ventures) — comma/space separated. e.g. John's account.
STUDIO_ADMIN_EMAILS=john.gallagher@wealthcx.com

# Server-side GitHub read token (org-scoped PAT for v0; GitHub App is the production path).
# Used by lib/github to render lanes/tickets (FB-006/007/008). Never exposed to the browser.
GITHUB_TOKEN=

# Test-only: set to 1 to enable the credentials sign-in used by Playwright. NEVER in production.
# E2E_TEST_LOGIN=1
